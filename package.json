{
  "name": "astro-static-template",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:watch": "concurrently \"astro dev\" \"chokidar 'src/assets/img/**/*' -c 'npm run compress:img'\"",
    "build": "npm run compress:img && astro build",
    "build:beautify": "npm run compress:img && astro build && npm run beautify",
    "preview": "astro preview",
    "astro": "astro",
    "lint:prettier": "prettier --check .",
    "lint:check": "npm run lint:html && npm run lint:style && npm run lint:es",
    "lint:html": "markuplint 'src/**/*.{html,astro}'",
    "lint:es": "eslint 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "lint:style": "stylelint 'src/**/*.{css,scss,astro}'",
    "lint:fix": "stylelint --fix 'src/**/*.{css,scss,astro}' && eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "compress:img": "node ./integration/convertImage.mjs -i ./src/assets/img -o ./public/img -w -v -t",
    "beautify": "node ./integration/js-beautify.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^5.16.15",
    "astro-icon": "^1.1.5",
    "kiso.css": "^1.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@markuplint/astro-parser": "^4.6.22",
    "autoprefixer": "^10.4.23",
    "budoux": "^0.6.3",
    "chokidar-cli": "^3.0.0",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unicorn": "^62.0.0",
    "fs-extra": "^11.3.3",
    "globals": "^16.5.0",
    "js-beautify": "^1.15.4",
    "markuplint": "^4.14.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.97.3",
    "sharp": "^0.34.5",
    "stylelint": "^16.26.1",
    "stylelint-config-recess-order": "^7.6.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "svgo": "^3.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite-plugin-sass-glob-import": "^5.0.0"
  },
  "browserslist": [
    "baseline widely available"
  ]
}
